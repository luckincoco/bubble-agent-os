# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI API Key (optional)
# OPENAI_API_KEY=sk-your-key-here

# Default LLM provider: deepseek | openai | ollama
LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Data directory (default: ~/.bubble-agent/data)
# DATA_DIR=/path/to/data

# Auth
# JWT_SECRET=your-secret-key
# DEFAULT_PASSWORD=changeme
# SERVICE_API_KEY=your-service-api-key

# Bobi bot password (defaults to DEFAULT_PASSWORD)
# BOBI_PASSWORD=change-me

# Feishu (optional)
# FEISHU_APP_ID=your-app-id
# FEISHU_APP_SECRET=your-app-secret

# Tencent Cloud OCR (optional, P2-1)
# TENCENT_SECRET_ID=your-secret-id
# TENCENT_SECRET_KEY=your-secret-key
# TENCENT_REGION=ap-guangzhou

# Tavily Web Search (optional)
# TAVILY_API_KEY=your-tavily-api-key

# Embedding model (optional)
# EMBEDDING_MODEL=text-embedding-ada-002

# Feature flags
# FOCUS_TRACKING=true
# SEMANTIC_BRIDGE=true
# SURPRISE_DETECTION=true
