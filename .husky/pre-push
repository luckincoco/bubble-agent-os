#!/bin/sh

# Secret scanning before push
# Block push if any secrets are detected in staged/committed files

echo "Running secret scan before push..."

# Patterns to detect
PATTERNS=(
  'sk-[a-zA-Z0-9]{20,}'          # API keys (OpenAI/DeepSeek style)
  'AKIA[0-9A-Z]{16}'             # AWS Access Key
  'ghp_[a-zA-Z0-9]{36}'          # GitHub Personal Access Token
  'gho_[a-zA-Z0-9]{36}'          # GitHub OAuth Token
  'password\s*[:=]\s*["\x27][^"\x27]{6,}'  # Hardcoded passwords
  '[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}'  # IP addresses (non-localhost)
)

FOUND=0

for pattern in "${PATTERNS[@]}"; do
  # Search tracked files (excluding test files, .env.example, and this hook itself)
  MATCHES=$(git diff --cached --diff-filter=ACMR -S "$pattern" -- \
    ':!.env*' ':!*.test.ts' ':!*.test.js' ':!.husky/*' ':!node_modules/*' \
    2>/dev/null | grep -E "^\+" | grep -vE "^(\+\+\+)" || true)
  
  if [ -n "$MATCHES" ]; then
    # Filter out localhost IPs for IP pattern
    if echo "$pattern" | grep -q "0-9.*0-9.*0-9.*0-9"; then
      MATCHES=$(echo "$MATCHES" | grep -vE '127\.0\.0\.1|0\.0\.0\.0|localhost' || true)
    fi
    if [ -n "$MATCHES" ]; then
      echo "BLOCKED: Potential secret detected matching pattern: $pattern"
      echo "$MATCHES"
      FOUND=1
    fi
  fi
done

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "Push blocked: potential secrets detected."
  echo "Remove secrets and try again, or use --no-verify to bypass (not recommended)."
  exit 1
fi

echo "Secret scan passed."
