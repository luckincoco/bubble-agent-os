{
  "name": "bubble-agent-os",
  "version": "0.1.0",
  "description": "Personal AI Agent powered by Bubble Theory",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bubble": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "pnpm --filter bubble-web build",
    "build:all": "pnpm build:web && pnpm build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "personal-assistant",
    "bubble-theory"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.8.2",
    "ulid": "^3.0.2",
    "xlsx": "^0.18.5"
  }
}
