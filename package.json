{
  "name": "bubble-agent-os",
  "version": "1.0.5",
  "description": "Personal AI Agent powered by Bubble Theory",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bubble": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "pnpm --filter bubble-web build",
    "build:all": "pnpm build:web && pnpm build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "personal-assistant",
    "bubble-theory"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ],
    "overrides": {
      "fast-jwt": ">=6.2.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "node scripts/check-secrets.mjs"
    ]
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@wecom/crypto": "^1.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^5.5.7",
    "fastify": "^5.8.2",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "tencentcloud-sdk-nodejs-ocr": "^4.1.198",
    "ulid": "^3.0.2",
    "xlsx": "^0.18.5"
  }
}
